# -------------------------------------------------------
# Variables de entorno para SYNCA
# Copia este archivo como .env y ajusta los valores
# -------------------------------------------------------

FLASK_APP=run.py
FLASK_ENV=development

# Clave secreta para sesiones Flask (¡CAMBIAR en producción!)
SECRET_KEY=synca-unefa-secret-2026-cambiar-en-produccion

# Base de datos:
# Dejar vacío = SQLite automático en instance/synca_dev.db (recomendado para desarrollo)
# Para PostgreSQL: DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db
DATABASE_URL=

# Solo True en producción con HTTPS
SESSION_COOKIE_SECURE=False

# Puerto del servidor (defecto: 5000)
PORT=5000
